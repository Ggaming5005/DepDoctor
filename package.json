{
  "name": "depdoctor",
  "version": "1.0.1",
  "description": "Analyze dependency health for npm projects - detect bloat, outdated packages, vulnerabilities, and unused dependencies",
  "type": "module",
  "bin": {
    "depdoctor": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "dashboard/",
    "data/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node -e \"const fs=require('fs');fs.cpSync('dashboard','dist/dashboard',{recursive:true});fs.cpSync('data','dist/data',{recursive:true})\"",
    "dev": "tsx bin/cli.ts",
    "lint": "eslint src/ bin/ --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "dependencies",
    "health",
    "audit",
    "npm",
    "outdated",
    "vulnerabilities",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ggaming5005/depdoctor.git"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "depcheck": "^1.4.7",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "semver": "^7.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
